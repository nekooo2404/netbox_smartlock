API_TOKEN_PEPPER_1=replace-with-random-string
ALLOWED_HOSTS=localhost netbox.localtest.me
CORS_ORIGIN_ALLOW_ALL=False
CORS_ORIGIN_WHITELIST=http://localhost:8000 http://netbox.localtest.me:8000
DB_HOST=postgres
DB_NAME=netbox
DB_PASSWORD=change-me
DB_USER=postgres
DB_PORT=5432
EMAIL_FROM=netbox@example.com
EMAIL_PASSWORD=
EMAIL_PORT=25
EMAIL_SERVER=localhost
EMAIL_SSL_CERTFILE=
EMAIL_SSL_KEYFILE=
EMAIL_TIMEOUT=5
EMAIL_USERNAME=netbox
EMAIL_USE_SSL=false
EMAIL_USE_TLS=false
GRANIAN_BACKPRESSURE=4
GRANIAN_WORKERS=4
GRAPHQL_ENABLED=true
MEDIA_ROOT=/opt/netbox/netbox/media
METRICS_ENABLED=false
REDIS_CACHE_DATABASE=1
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_INSECURE_SKIP_TLS_VERIFY=false
REDIS_CACHE_PASSWORD=change-me
REDIS_CACHE_SSL=false
REDIS_DATABASE=0
REDIS_HOST=redis
REDIS_INSECURE_SKIP_TLS_VERIFY=false
REDIS_PASSWORD=change-me
REDIS_SSL=false
RELEASE_CHECK_URL=https://api.github.com/repos/netbox-community/netbox/releases
SECRET_KEY=replace-with-django-secret-key
SKIP_SUPERUSER=false
WEBHOOKS_ENABLED=true
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Local Keycloak / OpenID Connect SSO. Use with docker-compose.keycloak.yml.
REMOTE_AUTH_ENABLED=True
REMOTE_AUTH_AUTO_CREATE_USER=True
REMOTE_AUTH_BACKEND=social_core.backends.google.GoogleOAuth2 social_core.backends.open_id_connect.OpenIdConnectAuth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=<google-client-id>
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=<google-client-secret>
SOCIAL_AUTH_OIDC_KEY=netbox-dev
SOCIAL_AUTH_OIDC_SECRET=netbox-dev-secret
SOCIAL_AUTH_OIDC_OIDC_ENDPOINT=http://keycloak.localtest.me:8080/realms/netbox-dev
SOCIAL_AUTH_OIDC_SCOPE=openid email profile
SOCIAL_AUTH_OIDC_JWT_ALGORITHMS=RS256
KEYCLOAK_HOSTNAME=http://keycloak.localtest.me:8080
KEYCLOAK_BASE_URL=http://keycloak.localtest.me:8080
KEYCLOAK_CLIENT_ID=netbox-dev
KEYCLOAK_CLIENT_SECRET=netbox-dev-secret
KEYCLOAK_CLIENT_REDIRECT_URIS=http://localhost:8000/oauth/complete/oidc/ http://netbox.localtest.me:8000/oauth/complete/oidc/
KEYCLOAK_CLIENT_WEB_ORIGINS=http://localhost:8000 http://netbox.localtest.me:8000
KEYCLOAK_CLIENT_POST_LOGOUT_REDIRECT_URIS=http://localhost:8000/oauth/disconnect/oidc/ http://netbox.localtest.me:8000/oauth/disconnect/oidc/ http://localhost:8000/login/ http://netbox.localtest.me:8000/login/ http://localhost:8000/* http://netbox.localtest.me:8000/*
KEYCLOAK_GOOGLE_CLIENT_ID=
KEYCLOAK_GOOGLE_CLIENT_SECRET=
KEYCLOAK_GOOGLE_DEFAULT_SCOPE=openid profile email
CSRF_TRUSTED_ORIGINS=http://localhost:8000 http://netbox.localtest.me:8000 http://keycloak.localtest.me:8080
LOGOUT_REDIRECT_URL=http://keycloak.localtest.me:8080/realms/netbox-dev/protocol/openid-connect/logout?client_id=netbox-dev&post_logout_redirect_uri=http%3A%2F%2Flocalhost%3A8000%2Flogin%2F
KEYCLOAK_GROUP_SYNC_ENABLED=True
KEYCLOAK_GROUP_SYNC_GROUPS=Admin Guest
KEYCLOAK_GROUP_SYNC_REMOVE=True
KEYCLOAK_GROUP_SYNC_GROUP_MAP=dcim-admin=Admin dcim-guest=Guest
KEYCLOAK_GROUP_SYNC_ROLE_MAP=dcim-admin=Admin dcim-guest=Guest
KEYCLOAK_SCOPE_SYNC_ENABLED=True
KEYCLOAK_SCOPE_SYNC_REMOVE=True
KEYCLOAK_SCOPE_SYNC_REGION_CLAIM=dcim_regions
KEYCLOAK_SCOPE_SYNC_SITE_CLAIM=dcim_sites
KEYCLOAK_SCOPE_SYNC_PERMISSION_PREFIX=SmartLock Keycloak Scope

# Production hardening notes:
# - Use HTTPS public domains, for example:
#   ALLOWED_HOSTS=netbox.example.com
#   CORS_ORIGIN_WHITELIST=https://netbox.example.com
#   CSRF_TRUSTED_ORIGINS=https://netbox.example.com https://sso.example.com
#   SOCIAL_AUTH_OIDC_OIDC_ENDPOINT=https://sso.example.com/realms/netbox
#   KEYCLOAK_CLIENT_REDIRECT_URIS=https://netbox.example.com/oauth/complete/oidc/
#   KEYCLOAK_CLIENT_WEB_ORIGINS=https://netbox.example.com
#   KEYCLOAK_CLIENT_POST_LOGOUT_REDIRECT_URIS=https://netbox.example.com/oauth/disconnect/oidc/ https://netbox.example.com/login/ https://netbox.example.com/*
#   LOGOUT_REDIRECT_URL=https://sso.example.com/realms/netbox/protocol/openid-connect/logout
#   SECURE_SSL_REDIRECT=True
#   SECURE_HSTS_SECONDS=31536000
#   SECURE_HSTS_INCLUDE_SUBDOMAINS=True
#   SECURE_HSTS_PRELOAD=True
# - Put SECRET_KEY, API_TOKEN_PEPPER_1, DB/Redis passwords, OIDC client secret,
#   Keycloak admin password, and LDAP bind password in Docker/Kubernetes secrets.
# - Use LDAPS from Keycloak to LDAP:
#   KEYCLOAK_LDAP_CONNECTION_URL=ldaps://ldap.example.com:636
#   KEYCLOAK_LDAP_USE_TRUSTSTORE_SPI=always
